# Delivered decks — outputs, not reference material.
# Excluding prevents the agent from reading past deliveries and
# copying stale content or layouts into a new build.
apps/

# Input drafts — read explicitly when named, not auto-indexed.
# There may be several drafts in specs/; the agent reads only the one
# the user points to, via an explicit Read call. Keeping them out of
# the index stops past drafts from bleeding content into a new build.
specs/
