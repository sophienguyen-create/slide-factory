#!/usr/bin/env bash
# ONX Scaffold pre-commit hook
# Install: cp scripts/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

set -e

CORE="template/core.css"          # single source of truth for the version
SHELL_DOC="template/layout-shell.html"
DESIGN="docs/design-system.html"
CHANGELOG="CHANGELOG.md"

# Only run checks if the core or either reference doc is staged
STAGED=$(git diff --cached --name-only | grep -E "^(template/core\.(css|js)|template/layout-shell\.html|docs/design-system\.html)$" || true)

if [ -z "$STAGED" ]; then
  exit 0
fi

echo "ONX Scaffold: running version checks…"

# 1. The canonical version comes from the core.css header (e.g. "core.css — v4.0.0 — …")
v_core=$(grep -m1 'ONX Scaffold core.css' "$CORE" | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' || true)

if [ -z "$v_core" ]; then
  echo "ERROR: No version found in $CORE header. Expect: 'ONX Scaffold core.css — vX.Y.Z — …'"
  exit 1
fi

# 2. layout-shell + design-system <meta> versions must match core.css
for f in "$SHELL_DOC" "$DESIGN"; do
  v=$(grep -m1 'onx-scaffold-version' "$f" | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' || true)
  if [ -z "$v" ]; then
    echo "ERROR: No version found in $f. Add: <meta name=\"onx-scaffold-version\" content=\"X.Y.Z\">"
    exit 1
  fi
  if [ "$v" != "$v_core" ]; then
    echo "ERROR: Version mismatch — core.css=$v_core, $f=$v"
    echo "Bump every reference to match core.css before committing."
    exit 1
  fi
done

# 3. CHANGELOG must be staged in the same commit
CHANGELOG_STAGED=$(git diff --cached --name-only | grep "^$CHANGELOG$" || true)
if [ -z "$CHANGELOG_STAGED" ]; then
  echo "ERROR: $CHANGELOG not staged. Update the changelog before committing core/reference changes."
  exit 1
fi

echo "ONX Scaffold: version $v_core — checks passed ✓"
exit 0
