#!/usr/bin/env bash
# Slide Factory pre-commit hook
# Install: cp scripts/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
#
# Enforces: when the brand core or the brand guidelines change, the brand-core
# version must be present and the CHANGELOG must be updated in the same commit.

set -e

CORE="template/brand-core.md"            # single source of truth for the version
GUIDELINES="docs/nexus-frontier-brand-guidelines.md"
CHANGELOG="CHANGELOG.md"

# Only run checks if the brand core or the guidelines are staged
STAGED=$(git diff --cached --name-only | grep -E "^(template/brand-core\.md|docs/nexus-frontier-brand-guidelines\.md)$" || true)

if [ -z "$STAGED" ]; then
  exit 0
fi

echo "Slide Factory: running version checks…"

# 1. The canonical version comes from the brand-core header
#    (e.g. "Slide Factory brand-core — v1.0.0 — …")
v_core=$(grep -m1 'brand-core' "$CORE" | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' || true)

if [ -z "$v_core" ]; then
  echo "ERROR: No version found in $CORE header. Expect: 'Slide Factory brand-core — vX.Y.Z — …'"
  exit 1
fi

# 2. CHANGELOG must be staged in the same commit
CHANGELOG_STAGED=$(git diff --cached --name-only | grep "^$CHANGELOG$" || true)
if [ -z "$CHANGELOG_STAGED" ]; then
  echo "ERROR: $CHANGELOG not staged. Update the changelog before committing brand-core / guidelines changes."
  exit 1
fi

# 3. The current brand-core version should appear in the CHANGELOG
if ! grep -q "$v_core" "$CHANGELOG"; then
  echo "ERROR: brand-core version $v_core not found in $CHANGELOG. Add a matching entry."
  exit 1
fi

echo "Slide Factory: version $v_core — checks passed ✓"
exit 0
